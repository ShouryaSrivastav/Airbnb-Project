
// Integration Code

create or replace storage integration airbnb_aws_integration
type= external_stage
storage_provider = 's3'
enabled = true
storage_aws_role_arn = 'arn:aws:iam::950742490128:role/Airbnb-Project-Role'
storage_allowed_locations = ('s3://airbnb-dataset-csv')
comment='optional comment'

desc storage integration airbnb_aws_integration

//Also Don't Forget To Change The Trust Policy Of AWS Role

//Loading Data

create database airbnb_project;

use airbnb_project;

create schema airp;

create or replace stage airbnb_proj_stage
url = 's3://airbnb-dataset-csv'
storage_integration = airbnb_aws_integration

create or replace file format airp_file_format
type = 'csv'
field_delimiter = ','
parse_header = true
field_optionally_enclosed_by = '"'

select * 
from table(
    infer_schema(
        LOCATION => '@airbnb_proj_stage',
        FILE_FORMAT => 'airp_file_format'
    
    )
)

create or replace table airbnb_dataset
using template(
    select array_agg(object_construct(*))
    from table(
        infer_schema(
            LOCATION => '@airbnb_proj_stage',
            FILE_FORMAT => 'airp_file_format'
        )
    
    )
    
)

copy into airbnb_dataset
from '@airbnb_proj_stage'
file_format = 'airp_file_format'
MATCH_BY_COLUMN_NAME = CASE_INSENSITIVE;



select count(*)
from airbnb_dataset


select * from airbnb_dataset

// Created Another Table For Data Cleaning

create or replace table airbnb_cleaned
using template(
    select array_agg(object_construct(*))
        from table(
            infer_schema(
                location => '@airbnb_proj_stage',
                FILE_FORMAT => 'airp_file_format'
            )
        )
)

